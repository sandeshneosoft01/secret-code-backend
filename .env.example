# Environment Configuration
NODE_ENV=development
PORT=8000
TZ=UTC

# MongoDB Configuration
MONGO_DB_NAME=secret-message
MONGO_URI=mongodb://localhost:27017/
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_POOL_SIZE=10

# Security and JWT
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_VALIDITY_SEC=86400
REFRESH_TOKEN_VALIDITY_SEC=604800
TOKEN_ISSUER=secret-message-api
TOKEN_AUDIENCE=secret-message-app
ENCRYPTION_SECRET=your_encryption_secret_here

# CORS Configuration
CORS_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Firebase Configuration
# FIREBASE_SERVICE_ACCOUNT must be a JSON string
FIREBASE_SERVICE_ACCOUNT='{}'

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Logging and Cache
LOG_DIR=logs
CONTENT_CACHE_DURATION_MILLIS=600000
